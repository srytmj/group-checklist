# ── Application ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# Generate with: openssl rand -hex 32
JWT_SECRET=replace-this-with-a-random-64-char-secret

# ── Database: Neon (default) ──────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.us-east-1.aws.neon.tech/dbname?sslmode=prefer
DB_SSL=prefer

# ── Database: AWS RDS (uncomment + fill to use RDS instead) ───
# DATABASE_URL=postgresql://master_user:password@your-db.xxxx.us-east-1.rds.amazonaws.com:5432/group_checklist
# DB_SSL=require

# ── Database: local dev (no SSL) ─────────────────────────────
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/group_checklist
# DB_SSL=disable
